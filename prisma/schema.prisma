// Naia E-commerce Database Schema
// Improved version with validations and indexes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  FEMALE
  MALE
  UNISEX
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  EN_PROCESO
  ENTREGADO
  CANCELADO
}

enum ChatStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Product {
  id             Int      @id @default(autoincrement())
  barcode        String?  @unique
  name           String
  description    String?
  imageUrl       String?
  unitPrice      Decimal  @db.Decimal(10, 2)
  wholesalePrice Decimal  @db.Decimal(10, 2)
  presentation   String   @default("Unidad")
  category       String   @default("General")
  gender         Gender   @default(FEMALE)
  isBestSeller   Boolean  @default(false)
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([category])
  @@index([gender])
  @@index([stock])
  @@index([isBestSeller])
  @@index([createdAt(sort: Desc)])
}

model StoryGroup {
  id           Int          @id @default(autoincrement())
  name         String
  thumbnailUrl String
  gender       Gender       @default(FEMALE)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  slides       StorySlide[]
}

model StorySlide {
  id        Int        @id @default(autoincrement())
  groupId   Int
  group     StoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  mediaUrl  String
  type      String     @default("IMAGE") // IMAGE or VIDEO
  duration  Int        @default(5000)    // ms
  order     Int        @default(0)
  createdAt DateTime   @default(now())
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String?
  phone         String?
  role          Role           @default(USER)
  whatsappOptIn Boolean        @default(false)
  createdAt     DateTime       @default(now())
  orders        Order[]
  conversations Conversation[]

  @@index([role])
  @@index([createdAt(sort: Desc)])
}

model Conversation {
  id          String    @id @default(uuid())
  phone       String    @unique
  name        String?
  status      ChatStatus @default(OPEN)
  unreadCount Int       @default(0)
  lastMessage String?
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([unreadCount])
  @@index([updatedAt(sort: Desc)])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  externalId     String?      @unique
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         String       // USER, ADMIN, SYSTEM
  content        String
  type           MessageType  @default(TEXT)
  status         MessageStatus @default(SENT)
  createdAt      DateTime     @default(now())
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int?
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String?
  customerPhone String?
  customerAddress String?
  items         String      // JSON string of cart items
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDIENTE)
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([total])
}

model Setting {
  id                  Int      @id @default(1)
  storeName           String   @default("Naia Beauty Store")
  supportEmail        String   @default("soporte@naia.com")
  mainAddress         String   @default("Av. Principal 123, Lima, Perú")
  buyWhatsAppNumber   String   @default("51944399377")
  whatsappPhoneId     String?
  whatsappVerifyToken String?
  whatsappStatus      String   @default("Conectado")
  notifyOrderWS       Boolean  @default(true)
  notifyLowStockEmail Boolean  @default(true)
  weeklySalesSummary  Boolean  @default(false)
  twoFactorAuth       Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}
