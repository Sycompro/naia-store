// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  imageUrl       String?
  unitPrice      Float
  wholesalePrice Float
  presentation   String   @default("Unidad")
  category       String   @default("General")
  gender         String   @default("FEMALE") // FEMALE, MALE
  isBestSeller   Boolean  @default(false)
  stock          Int      @default(0)
  createdAt      DateTime @default(now())
}

model Story {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  gender    String   @default("FEMALE") // FEMALE, MALE
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String?
  phone         String?
  role          String         @default("USER") // USER, ADMIN
  whatsappOptIn Boolean        @default(false)
  createdAt     DateTime       @default(now())
  orders        Order[]
  conversations Conversation[]
}

model Conversation {
  id          String    @id @default(uuid())
  phone       String    @unique
  name        String?
  status      String    @default("OPEN") // OPEN, CLOSED, ARCHIVED
  unreadCount Int       @default(0)
  lastMessage String?
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  createdAt   DateTime  @default(now())
}

model Message {
  id             String       @id @default(uuid())
  externalId     String?      @unique  // ID de la plataforma externa (WhatsApp)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         String       // USER, ADMIN, SYSTEM
  content        String
  type           String       @default("TEXT") // TEXT, IMAGE, DOCUMENT
  status         String       @default("SENT") // SENT, DELIVERED, READ, FAILED
  createdAt      DateTime     @default(now())
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  items      String   // JSON string of cart items
  total      Float
  status     String   @default("PENDIENTE") // PENDIENTE, EN_PROCESO, ENTREGADO, CANCELADO
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  id                  Int      @id @default(1)
  storeName           String   @default("Naia Beauty Store")
  supportEmail        String   @default("soporte@naia.com")
  mainAddress         String   @default("Av. Principal 123, Lima, Perú")
  whatsappPhoneId     String?
  whatsappVerifyToken String?
  whatsappStatus      String   @default("Conectado")
  notifyOrderWS       Boolean  @default(true)
  notifyLowStockEmail Boolean  @default(true)
  weeklySalesSummary  Boolean  @default(false)
  twoFactorAuth       Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}
